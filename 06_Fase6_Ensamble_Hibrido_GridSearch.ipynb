        "def plot_matriz_hibrida(cm, titulo, ax):\n",
        "    sns.heatmap(cm, annot=True, fmt='d', cmap='Blues',\n",
        "                xticklabels=['Alerta (0)', 'Baja Vig. (5)', 'Dormido (10)'],\n",
        "                yticklabels=['Alerta (0)', 'Baja Vig. (5)', 'Dormido (10)'],\n",
        "                cbar=False, annot_kws={\"size\": 14}, ax=ax)\n",
        "    ax.set_title(titulo, fontsize=14, pad=15)\n",
        "    ax.set_ylabel('Clase Real', fontsize=12)\n",
        "    ax.set_xlabel('Clase Predicha', fontsize=12)\n",
        "\n",
        "fig, axes = plt.subplots(1, 2, figsize=(14, 6))\n",
        "\n",
        "plot_matriz_hibrida(m1['Matriz'], f\"M1: Máxima Exactitud (PERCLOS: {m1['PERCLOS_th']:.2f})\", axes[0])\n",
        "plot_matriz_hibrida(m4['Matriz'], f\"M4: Seguridad Total (PERCLOS: {m4['PERCLOS_th']:.2f})\", axes[1])\n",
        "\n",
        "plt.tight_layout()\n",
        "plt.savefig(os.path.join(ruta_base, 'confusion_hibrido_Fase6.png'), dpi=300, bbox_inches='tight')\n",
