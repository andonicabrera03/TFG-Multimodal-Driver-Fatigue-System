,\n        \"max\": 0.4100032448768616,\n        \"num_unique_values\": 3,\n        \"samples\": [\n          0.017055362462997437\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    },\n    {\n      \"column\": \"prob_bostezo\",\n      \"properties\": {\n        \"dtype\": \"number\",\n        \"std\": 0.30591784241621045,\n        \"min\": 0.23092027008533478,\n        \"max\": 0.8423120975494385,\n        \"num_unique_values\": 3,\n        \"samples\": [\n          0.23092027008533478\n        ],\n        \"semantic_type\": \"\",\n        \"description\": \"\"\n      }\n    }\n  ]\n}"
