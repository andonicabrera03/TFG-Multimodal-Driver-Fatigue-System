        "print(\"=======================================================================================\")\n",
        "print(\"EVALUACIÓN CRÍTICA DE ESTRATEGIAS (EL DILEMA DE SEGURIDAD - NAVAJA DE OCKHAM)\")\n",
        "print(\"=======================================================================================\\n\")\n",
        "\n",
        "# M1: Máxima Exactitud General (Max Accuracy)\n",
        "m1 = df_resultados.loc[df_resultados['Accuracy'].idxmax()]\n",
        "\n",
        "# M2: Máxima Puntuación F1 Estadística\n",
        "m2 = df_resultados.loc[df_resultados['F1_Score'].idxmax()]\n",
        "\n",
        "# M3: ADAS Comercial Equilibrado (FN <= 8 y Especificidad > 0.50, max Acc)\n",
        "filtro_m3 = df_resultados[(df_resultados['Falsos_Negativos'] <= 8) & (df_resultados['Especificidad'] > 0.50)]\n",
        "m3 = filtro_m3.loc[filtro_m3['Accuracy'].idxmax()] if not filtro_m3.empty else m1\n",
        "\n",
        "# M4: Seguridad Viable Total (Prioriza minimizar FN, max F1)\n",
        "min_fn = df_resultados['Falsos_Negativos'].min()\n",
        "filtro_m4 = df_resultados[df_resultados['Falsos_Negativos'] == min_fn]\n",
        "m4 = filtro_m4.loc[filtro_m4['F1_Score'].idxmax()]\n",
        "\n",
        "modelos_clave = [(\"M1: Máxima Exactitud\", m1),\n",
        "                 (\"M2: Máxima F1 Estadística\", m2),\n",
        "                 (\"M3: ADAS Equilibrado\", m3),\n",
        "                 (\"M4: Seguridad Total\", m4)]\n",
        "\n",
        "print(f\"{'Modelo':<25} | {'Alpha':<6} | {'PERCLOS':<7} | {'MAR_th':<6} | {'Acc (%)':<7} | {'F1 Score':<8} | {'Especif(%)':<10} | {'Falsos Neg'}\")\n",
        "print(\"-\" * 105)\n",
        "for nombre, m in modelos_clave:\n",
        "    print(f\"{nombre:<25} | {m['Alpha (Geom)']:.2f}   | {m['PERCLOS_th']:.2f}   | {m['MAR_th']:.2f}   | {m['Accuracy']*100:.1f}   | {m['F1_Score']:.3f}    | {m['Especificidad']*100:.1f}      | {m['Falsos_Negativos']}\")"
      ],
