    {
      "cell_type": "code",
      "source": [
        "# Para acelerar el Grid Search, calculamos el umbral geométrico dinámico (EAR_th)\n",
        "# de cada vídeo una sola vez (Periodo de Warm-up W=20s a 5 FPS = 100 frames)\n",
        "\n",
        "print(\"Ejecutando Calibración Biométrica Asíncrona (W=20s)...\")\n",
        "fps = 5\n",
        "warm_up_frames = 20 * fps\n",
        "\n",
        "dict_umbrales_geom = {}\n",
        "\n",
        "for video in videos_unicos:\n",
        "    df_video = df_hibrido[df_hibrido['video'] == video]\n",
        "\n",
        "    # Extraer media y desviación del EAR basal\n",
        "    mu_ear = df_video['ear'].head(warm_up_frames).mean()\n",
        "    sigma_ear = df_video['ear'].head(warm_up_frames).std()\n",
        "\n",
        "    # Límite duro de seguridad (max(mu - 2*sigma, 0.18))\n",
        "    if pd.notnull(mu_ear) and pd.notnull(sigma_ear):\n",
        "        ear_th_dinamico = max(mu_ear - 2 * sigma_ear, 0.18)\n",
        "    else:\n",
        "        ear_th_dinamico = 0.22 # Fallback\n",
        "\n",
        "    dict_umbrales_geom[video] = ear_th_dinamico\n",
        "\n",
        "print(\"Calibración completada con éxito.\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "DES5sPjYM42L",
        "outputId": "15efb1d1-8b19-48de-ff9d-8ce75fe56b5b"
      },
      "execution_count": null,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Ejecutando Calibración Biométrica Asíncrona (W=20s)...\n",
            "Calibración completada con éxito.\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "def evaluar_video_hibrido(df_v, ear_th, mar_th, alpha, perclos_th, b_sec=1.5, fps=5):\n",
        "    beta = 1.0 - alpha\n",
        "\n",
        "    # 1. Binarización Geométrica\n",
        "    geom_ojo = (df_v['ear'] < ear_th).astype(float)\n",
        "    geom_boca = (df_v['mar'] > mar_th).astype(float)\n",
        "\n",
        "    # 2. Fusión Ponderada (Ecuación Soft Voting)\n",
        "    # df_v['prob_ojo_cerrado'] y df_v['prob_bostezo'] provienen de la MobileNetV2\n",
        "    p_final_ojo = (alpha * geom_ojo) + (beta * df_v['prob_ojo_cerrado'])\n",
        "    p_final_boca = (alpha * geom_boca) + (beta * df_v['prob_bostezo'])\n",
        "\n",
        "    # 3. Lógica Clínica (Fusión Tardía)\n",
        "    # Consideramos evento positivo si P_final > 0.5\n",
        "    frames_ojos_cerrados = (p_final_ojo > 0.5).sum()\n",
        "    perclos_actual = frames_ojos_cerrados / len(df_v)\n",
        "\n",
        "    # Filtro de Racha Maxilar (Bostezo)\n",
        "    racha_actual, max_racha = 0, 0\n",
        "    for val in p_final_boca:\n",
        "        if val > 0.5:\n",
        "            racha_actual += 1\n",
        "            if racha_actual > max_racha: max_racha = racha_actual\n",
        "        else:\n",
        "            racha_actual = 0\n",
        "\n",
        "    bostezo_segundos = max_racha / fps\n",
        "\n",
        "    # 4. Asignación Multiclase\n",
        "    if perclos_actual >= perclos_th:\n",
        "        return 10\n",
        "    elif bostezo_segundos >= b_sec:\n",
        "        return 5\n",
        "    else:\n",
        "        return 0"
      ],
      "metadata": {
        "id": "VqVGamU3M6hf"
      },
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "# Espacio Hiperparamétrico\n",
        "alphas = np.arange(0.30, 0.90, 0.05)       # Peso de la geometría (de 30% a 85%)\n",
        "perclos_ths = np.arange(0.05, 0.30, 0.05)  # Umbrales PERCLOS\n",
        "mar_ths = np.arange(0.30, 0.46, 0.05)      # Umbrales MAR\n",
        "b_sec = 1.5                                # Fijo basado en hallazgos de Fase 5\n",
        "\n",
        "resultados_grid = []\n",
        "\n",
        "print(\"Iniciando Grid Search Híbrido (MobileNetV2 + MediaPipe)...\")\n",
        "total_iters = len(alphas) * len(perclos_ths) * len(mar_ths)\n",
        "barra_progreso = tqdm(total=total_iters)\n",
        "\n",
        "# Extraer yemas para iteración rápida\n",
        "clases_reales = df_hibrido.groupby('video')['clase_real'].first().to_dict()\n",
        "\n",
        "for alpha, p_th, m_th in itertools.product(alphas, perclos_ths, mar_ths):\n",
        "    predicciones = []\n",
        "    reales = []\n",
        "\n",
        "    for video in videos_unicos:\n",
        "        df_v = df_hibrido[df_hibrido['video'] == video]\n",
        "        ear_th = dict_umbrales_geom[video]\n",
        "\n",
        "        pred_clase = evaluar_video_hibrido(df_v, ear_th, m_th, alpha, p_th, b_sec=b_sec, fps=5)\n",
        "\n",
        "        predicciones.append(pred_clase)\n",
        "        reales.append(clases_reales[video])\n",
        "\n",
        "    # Calcular Métricas\n",
        "    acc = accuracy_score(reales, predicciones)\n",
        "    f1 = f1_score(reales, predicciones, average='macro')\n",
        "\n",
        "    # Extraer Falsos Negativos Críticos (Dormido real=10, Predicho=0)\n",
        "    cm = confusion_matrix(reales, predicciones, labels=[0, 5, 10])\n",
        "    # Fila index 2 es clase 10. Columna index 0 es clase 0 predicha.\n",
        "    falsos_negativos = cm[2][0]\n",
        "\n",
        "    # Especificidad de Clase 0 (Evitar falsas alarmas)\n",
        "    # Fila index 0 es clase 0 real. TN es cm[0][0]\n",
        "    tn_0 = cm[0][0]\n",
        "    total_0_real = sum(cm[0])\n",
        "    especificidad_0 = tn_0 / total_0_real if total_0_real > 0 else 0\n",
        "\n",
        "    resultados_grid.append({\n",
        "        'Alpha (Geom)': alpha,\n",
        "        'PERCLOS_th': p_th,\n",
        "        'MAR_th': m_th,\n",
        "        'Accuracy': acc,\n",
        "        'F1_Score': f1,\n",
        "        'Especificidad': especificidad_0,\n",
        "        'Falsos_Negativos': falsos_negativos,\n",
        "        'Matriz': cm\n",
        "    })\n",
        "\n",
        "    barra_progreso.update(1)\n",
        "\n",
        "barra_progreso.close()\n",
        "df_resultados = pd.DataFrame(resultados_grid)\n",
        "print(\"Grid Search Completado.\")"
      ],
